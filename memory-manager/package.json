{
    "name": "virtual-plc-studio",
    "version": "1.0.1",
    "description": "Virtual PLC Studio for industrial register simulation",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "build:portable": "electron-builder --win portable"
    },
    "keywords": [
        "plc",
        "siemens",
        "mitsubishi",
        "delta",
        "modbus",
        "virtual"
    ],
    "author": "STI",
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "electron-packager": "^17.1.2"
    },
    "dependencies": {
        "electron-store": "^8.1.0"
    },
    "build": {
        "appId": "com.sti.virtual-plc-studio",
        "productName": "Virtual PLC Studio",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "renderer/**/*",
            "assets/**/*"
        ],
        "extraResources": [
            {
                "from": "../virtualHub",
                "to": "virtualHub",
                "filter": [
                    "**/*",
                    "!__pycache__/**"
                ]
            },
            {
                "from": "../virtualSiemens",
                "to": "virtualSiemens",
                "filter": [
                    "**/*",
                    "!__pycache__/**"
                ]
            },
            {
                "from": "../virtualDelta",
                "to": "virtualDelta",
                "filter": [
                    "**/*",
                    "!__pycache__/**"
                ]
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Virtual PLC Studio"
        }
    }
}
